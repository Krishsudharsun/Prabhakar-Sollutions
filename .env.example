# ─────────────────────────────────────────────
# SITE
# ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.yourdomain.com
NEXT_PUBLIC_SITE_NAME="ScaleForge"

# ─────────────────────────────────────────────
# DATABASE (Supabase Postgres via Prisma) — optional
# Only needed if you want lead/contact submissions persisted
# in your own DB in addition to email + CRM.
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/postgres?schema=public"

# ─────────────────────────────────────────────
# EMAIL (Resend)
# ─────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL="ScaleForge <hello@yourdomain.com>"
LEAD_NOTIFICATION_EMAIL=team@yourdomain.com

# ─────────────────────────────────────────────
# CRM (HubSpot) — leave blank to disable CRM sync
# ─────────────────────────────────────────────
HUBSPOT_PORTAL_ID=
HUBSPOT_CONTACT_FORM_GUID=
HUBSPOT_QUALIFICATION_FORM_GUID=
HUBSPOT_PRIVATE_APP_TOKEN=

# ─────────────────────────────────────────────
# BOOKING (Calendly)
# ─────────────────────────────────────────────
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-team/discovery-call

# ─────────────────────────────────────────────
# ANALYTICS & TRACKING — each is optional; scripts only
# load when their ID is present, and only after cookie consent.
# ─────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_CLARITY_PROJECT_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ─────────────────────────────────────────────
# SPAM PROTECTION (Cloudflare Turnstile) — optional
# ─────────────────────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─────────────────────────────────────────────
# CMS (Sanity) — only needed once you migrate the
# blog/resources from local data to Sanity
# ─────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
